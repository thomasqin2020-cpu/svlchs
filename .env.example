# Copy to .env.local for development. Set in Vercel → Settings → Environment Variables for production.
# All vars are optional — the app degrades gracefully when missing.

# ─── Supabase (auth + DB + storage) ────────────────────────────────────────
# From Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role bypasses RLS. NEVER expose to the browser. Used by Stripe webhook.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe (donations) ────────────────────────────────────────────────────
# See docs/STRIPE_SETUP.md for the full walkthrough.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Resend (transactional email) ──────────────────────────────────────────
RESEND_API_KEY=
# Verified domain on Resend. Use "onboarding@resend.dev" for sandbox.
RESEND_FROM_EMAIL=Spartan Vanguard <onboarding@resend.dev>
# Where new sign-ups / form submissions get forwarded.
OFFICER_NOTIFICATION_EMAIL=

# ─── Site URL (for magic-link redirects + email links) ─────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
